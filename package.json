{
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint",
    "pretest": "tsc --noEmit",
    "test": "pnpm -r test",
    "mdfix": "prettier *.md --write",
    "start": "pnpm -F example start",
    "build": "pnpm -r build",
    "build:compile": "pnpm -F zod-sockets build",
    "build:client": "pnpm -F example build:client",
    "build:docs": "pnpm -F example build:docs",
    "build:tests": "tsx tools/make-tests.ts",
    "precommit": "pnpm lint && pnpm test && pnpm build && git add example/example*.ts",
    "postversion": "git push && git push --tags",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build",
    "hooks": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.1",
    "@tsconfig/node20": "^20.1.5",
    "@types/node": "^25.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-allowed-dependencies": "^2.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.0.10",
    "prettier": "3.8.1",
    "tsdown": "^0.21.3",
    "tsx": "^4.7.0",
    "typescript": "catalog:dev",
    "typescript-eslint": "~8.55.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
