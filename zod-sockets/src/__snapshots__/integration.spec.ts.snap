exports[`Integration > print() > should handle circular references 1`] = `
"import type { Socket as SocketBase } from "socket.io-client";

export namespace Root {
    /** @desc The actual path of the Root namespace */
    export const path = "/";
    type Type1 = {
        title: string;
        features: Type1[];
    };
    export interface Emission {
    }
    export interface Actions {
        test: (p1: Type1[]) => void;
    }
    /** @example const socket: Root.Socket = io(Root.path) */
    export type Socket = SocketBase<Emission, Actions>;
}"
`;

exports[`Integration > print() > should handle namespaces with emission 1`] = `
